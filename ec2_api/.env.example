# .env.example — copy to .env for local development, fill in real values.
# .env is in .gitignore and must NEVER be committed.
#
# On EC2 (production): secrets are loaded from SSM Parameter Store automatically.
# Set only the non-secret vars below on EC2 (e.g. in /etc/systemd/system/ec2_api.service
# under [Service] EnvironmentFile= or Environment= directives).
# ============================================================

# ---------- AWS ----------
AWS_REGION=ap-northeast-1
S3_BUCKET=al-lab-s3-XXXXXXXXXX

# ---------- RDS (non-secret) ----------
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres

# ---------- App ----------
JWT_TTL_SEC=60

# SSM prefix (default: /bess/app, change for staging/prod separation)
# SSM_PREFIX=/bess/app

# ---------- Secrets (LOCAL DEV ONLY) ----------
# On EC2: leave these unset — app will fetch from SSM automatically.
# Locally: set these so the app skips SSM calls.
#
# Generate SERVER_SECRET with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
SERVER_SECRET=REPLACE_ME_with_token_hex_32
DB_PASS=REPLACE_ME_with_rds_password
